<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<connectionStrings>

		<!-- Connection String cho SQL Server -->

		<!-- CÁCH 1: Windows Authentication (khuyến nghị) -->
		<add name="QuanLyThuCungConnection"
			 connectionString="Server=\.SQLEXPRESS;Database=QuanLyThuCung;Integrated Security=True;TrustServerCertificate=True;"
			 providerName="System.Data.SqlClient" />

		<!-- CÁCH 2: SQL Server Authentication -->
		<!--
    <add name="QuanLyThuCungConnection" 
         connectionString="Server=\.SQLEXPRESS;Database=QuanLyThuCung;User Id=sa;Password=YourPassword;TrustServerCertificate=True;" 
         providerName="System.Data.SqlClient" />
    -->

		<!-- CÁCH 3: SQL Server Express -->
		<!--
    <add name="QuanLyThuCungConnection" 
         connectionString="Server=.\SQLEXPRESS;Database=QuanLyThuCung;Integrated Security=True;TrustServerCertificate=True;" 
         providerName="System.Data.SqlClient" />
    -->

		<!-- CÁCH 4: LocalDB -->
		<!--
    <add name="QuanLyThuCungConnection" 
         connectionString="Server=(localdb)\MSSQLLocalDB;Database=QuanLyThuCung;Integrated Security=True;TrustServerCertificate=True;" 
         providerName="System.Data.SqlClient" />
    -->

	</connectionStrings>

	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>

</configuration>